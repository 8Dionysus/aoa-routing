{
  "beacon_rules": [
    {
      "beacon_ref": "agon.routing.gate_trigger_recurrence",
      "decision_surface": "mechanics/agon/parts/gate-routing/docs/gate-routing.md",
      "kind": "automation_candidate",
      "match_categories": [
        "repeat_pattern",
        "review_signal"
      ],
      "match_signals": [
        "agon_stop_line_repeated",
        "agon_recurrence_surface_changed"
      ],
      "notes": "Repeated gate candidates are routing pressure, not arena activation.",
      "observation_inputs": [
        "agon-gate-routing-registry"
      ],
      "recommended_actions": [
        "refresh gate routing registry",
        "handoff candidate pressure to center; do not open arena"
      ],
      "status_ladder": [
        "hint",
        "watch",
        "candidate",
        "review_ready"
      ],
      "suppress_when": [
        "live_protocol_claim_present",
        "hidden_authority_detected"
      ],
      "target_repo": "aoa-routing",
      "thresholds": {
        "candidate_observations": 2,
        "min_unique_evidence_refs": 2,
        "min_unique_sources": 2,
        "review_ready_observations": 3,
        "watch_observations": 1
      }
    },
    {
      "beacon_ref": "agon.routing.arena_authority_overclaim",
      "decision_surface": "mechanics/agon/parts/gate-routing/docs/decision-boundary.md",
      "kind": "overclaim_alarm",
      "match_categories": [
        "overclaim_risk"
      ],
      "match_signals": [
        "live_protocol_claim_present"
      ],
      "notes": "Routing must not become arena sovereignty.",
      "observation_inputs": [
        "agon-gate-routing-registry"
      ],
      "recommended_actions": [
        "quarantine routing overclaim",
        "restore thin gate boundary"
      ],
      "status_ladder": [
        "hint",
        "watch",
        "candidate",
        "review_ready"
      ],
      "suppress_when": [
        "hidden_authority_detected"
      ],
      "target_repo": "aoa-routing",
      "thresholds": {
        "candidate_observations": 2,
        "min_unique_evidence_refs": 2,
        "min_unique_sources": 2,
        "review_ready_observations": 3,
        "watch_observations": 1
      }
    }
  ],
  "candidate_targets": [
    "mechanics/agon/parts/gate-routing/generated/agon_gate_routing_registry.min.json"
  ],
  "component_ref": "component:agon:gate-routing-surfaces",
  "consumer_edges": [
    {
      "kind": "handoff_home",
      "notes": "Owner remains the review home for its own Agon recurrence signals.",
      "required": true,
      "suggested_action": "observe",
      "suggested_commands": [],
      "target": "mechanics/agon/parts/recurrence-adapter/docs/recurrence-adapter.md",
      "target_repo": "aoa-routing"
    }
  ],
  "contract_surfaces": [
    "mechanics/agon/parts/gate-routing/docs/gate-routing.md",
    "mechanics/agon/parts/gate-routing/docs/trigger-model.md",
    "mechanics/agon/parts/gate-routing/docs/decision-boundary.md",
    "mechanics/agon/parts/gate-routing/docs/assistant-escalation.md",
    "mechanics/agon/parts/gate-routing/docs/owner-handoffs.md",
    "mechanics/agon/parts/recurrence-adapter/docs/recurrence-adapter.md"
  ],
  "decision_surfaces": [
    "mechanics/agon/parts/gate-routing/docs/gate-routing.md",
    "mechanics/agon/parts/gate-routing/docs/trigger-model.md"
  ],
  "description": "Pre-protocol Agon gate routing surfaces that detect when ordinary routing may no longer be honest.",
  "documentation_surfaces": [
    "mechanics/agon/parts/gate-routing/docs/gate-routing.md",
    "mechanics/agon/parts/gate-routing/docs/trigger-model.md",
    "mechanics/agon/parts/gate-routing/docs/decision-boundary.md",
    "mechanics/agon/parts/gate-routing/docs/assistant-escalation.md",
    "mechanics/agon/parts/gate-routing/docs/owner-handoffs.md",
    "mechanics/agon/parts/recurrence-adapter/docs/recurrence-adapter.md"
  ],
  "drift_signals": [
    {
      "recommended_action": "revalidate",
      "severity": "medium",
      "signal": "agon_surface_changed_without_recurrence_review"
    },
    {
      "recommended_action": "defer",
      "severity": "high",
      "signal": "agon_stop_line_blur_detected"
    }
  ],
  "freshness": {
    "open_window_days": 7,
    "repeat_trigger_threshold": 2,
    "stale_after_days": 14
  },
  "generated_surfaces": [
    "mechanics/agon/parts/gate-routing/generated/agon_gate_routing_registry.min.json"
  ],
  "observation_inputs": [
    {
