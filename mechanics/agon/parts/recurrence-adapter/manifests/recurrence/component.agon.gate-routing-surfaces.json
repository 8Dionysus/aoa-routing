  ],
  "owner_repo": "aoa-routing",
  "proof_surfaces": [
    "python mechanics/agon/parts/gate-routing/scripts/validate_agon_gate_routing.py"
  ],
  "refresh_routes": [
    {
      "action": "revalidate",
      "commands": [
        "python mechanics/agon/parts/gate-routing/scripts/validate_agon_gate_routing.py"
      ],
      "notes": "Owner-local validation path. Recurrence may suggest this route; it must not run it as hidden authority."
    }
  ],
  "rollback_anchors": [
    "mechanics/agon/parts/gate-routing/docs/gate-routing.md",
    "mechanics/agon/parts/gate-routing/docs/trigger-model.md"
  ],
  "schema_version": "aoa_recurrence_component_v2",
  "signal_edges": [
    {
      "kind": "summarized_by",
      "notes": "Center receives gate hints; routing does not activate arena.",
      "target": "component:agon:center-surfaces",
      "target_repo": "Agents-of-Abyss"
    },
    {
      "kind": "composed_by_playbook",
      "notes": "Trials may use gate triggers as scenario inputs.",
      "target": "component:agon:trial-playbook-surfaces",
