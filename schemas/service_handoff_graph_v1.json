{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/aoa-routing/schemas/service_handoff_graph_v1.json",
  "title": "Service Handoff Graph V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "edges",
    "evidence_refs",
    "id",
    "kind",
    "nodes",
    "notes",
    "owner_repo",
    "status",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "receipt_required",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "receipt_required": {
            "type": "boolean",
            "const": true
          },
          "to": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "minItems": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "service_handoff_graph_v1"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "aoa-routing"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
