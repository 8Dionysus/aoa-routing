{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/return-navigation-hints.schema.json",
  "title": "aoa-routing return navigation hints",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "thin_router_returns",
    "federation_root_returns",
    "federation_kind_returns"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "thin_router_returns": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/thinRouterReturn"
      }
    },
    "federation_root_returns": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/federationRootReturn"
      }
    },
    "federation_kind_returns": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/federationKindReturn"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repoName": {
      "type": "string",
      "enum": [
        "aoa-routing",
        "aoa-techniques",
        "aoa-skills",
        "aoa-evals",
        "aoa-memo",
        "aoa-agents",
        "aoa-playbooks",
        "aoa-kag",
        "Agents-of-Abyss",
        "Tree-of-Sophia"
      ]
    },
    "returnReason": {
      "type": "string",
      "enum": [
        "axis_lost",
        "artifact_contract_lost",
        "verification_lost",
        "source_boundary_lost",
        "authority_unclear",
        "checkpoint_continuity_needed",
        "reroute_required"
      ]
    },
    "supportedReturnReasons": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/returnReason"
      }
    },
    "routeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verb",
        "target_repo",
        "target_surface"
      ],
      "properties": {
        "verb": {
          "type": "string",
          "enum": [
            "pick",
            "inspect",
            "expand",
            "recall"
          ]
        },
        "target_repo": {
          "$ref": "#/$defs/repoName"
        },
        "target_surface": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "match_field": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_value": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "section_key_field": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "thinRouterReturn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_kind",
        "source_repo",
        "supported_return_reasons",
        "primary_action",
        "ownership_note"
      ],
      "properties": {
        "context_kind": {
          "type": "string",
          "enum": [
            "technique",
            "skill",
            "eval",
            "memo"
          ]
        },
        "source_repo": {
          "type": "string",
          "enum": [
            "aoa-techniques",
            "aoa-skills",
            "aoa-evals",
            "aoa-memo"
          ]
        },
        "supported_return_reasons": {
          "$ref": "#/$defs/supportedReturnReasons"
        },
        "primary_action": {
          "$ref": "#/$defs/routeAction"
        },
        "secondary_action": {
          "$ref": "#/$defs/routeAction"
        },
        "ownership_note": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "federationRootReturn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_id",
        "owner_repo",
        "supported_return_reasons",
        "primary_action",
        "fallback_action",
        "ownership_note"
      ],
      "properties": {
        "root_id": {
          "type": "string",
          "enum": [
            "aoa-root",
            "tos-root"
          ]
        },
        "owner_repo": {
          "type": "string",
          "enum": [
            "Agents-of-Abyss",
            "Tree-of-Sophia"
          ]
        },
        "supported_return_reasons": {
          "$ref": "#/$defs/supportedReturnReasons"
        },
        "primary_action": {
          "$ref": "#/$defs/routeAction"
        },
        "fallback_action": {
          "$ref": "#/$defs/routeAction"
        },
        "ownership_note": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "federationKindReturn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_kind",
        "owner_repo",
        "supported_return_reasons",
        "primary_action",
        "fallback_action",
        "ownership_note"
      ],
      "properties": {
        "entry_kind": {
          "type": "string",
          "enum": [
            "agent",
            "tier",
            "playbook",
            "kag_view"
          ]
        },
        "owner_repo": {
          "type": "string",
          "enum": [
            "aoa-agents",
            "aoa-playbooks",
            "aoa-kag"
          ]
        },
        "supported_return_reasons": {
          "$ref": "#/$defs/supportedReturnReasons"
        },
        "primary_action": {
          "$ref": "#/$defs/routeAction"
        },
        "fallback_action": {
          "$ref": "#/$defs/routeAction"
        },
        "ownership_note": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
