{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/federation-entrypoints.schema.json",
  "title": "aoa-routing federation entrypoints",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "source_inputs",
    "root_entries",
    "active_entry_kinds",
    "declared_entry_kinds",
    "entrypoints"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "source_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceInput"
      }
    },
    "root_entries": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/rootEntry"
      }
    },
    "active_entry_kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/activeEntryKind"
      }
    },
    "declared_entry_kinds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/declaredEntryKind"
      }
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entrypoint"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repoName": {
      "type": "string",
      "enum": [
        "aoa-routing",
        "aoa-techniques",
        "aoa-skills",
        "aoa-evals",
        "aoa-memo",
        "aoa-agents",
        "aoa-playbooks",
        "aoa-kag",
        "Agents-of-Abyss",
        "Tree-of-Sophia"
      ]
    },
    "ownerRepo": {
      "type": "string",
      "enum": [
        "aoa-agents",
        "aoa-playbooks",
        "aoa-kag",
        "Agents-of-Abyss",
        "Tree-of-Sophia"
      ]
    },
    "surfaceRef": {
      "type": "string",
      "pattern": "^(aoa-routing|aoa-techniques|aoa-skills|aoa-evals|aoa-memo|aoa-agents|aoa-playbooks|aoa-kag|Agents-of-Abyss|Tree-of-Sophia):.+$"
    },
    "activeEntryKind": {
      "type": "string",
      "enum": [
        "agent",
        "tier",
        "playbook",
        "kag_view"
      ]
    },
    "declaredEntryKind": {
      "type": "string",
      "enum": [
        "seed",
        "tos_node",
        "runtime_surface"
      ]
    },
    "nextHop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/activeEntryKind"
        },
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verb",
        "target_repo",
        "target_surface",
        "match_key",
        "target_value"
      ],
      "properties": {
        "verb": {
          "type": "string",
          "enum": [
            "pick",
            "inspect"
          ]
        },
        "target_repo": {
          "$ref": "#/$defs/repoName"
        },
        "target_surface": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "match_key": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target_value": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "entryBase": {
      "type": "object",
      "required": [
        "id",
        "owner_repo",
        "title",
        "capsule_surface",
        "authority_surface",
        "next_actions",
        "fallback",
        "risk",
        "next_hops"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner_repo": {
          "$ref": "#/$defs/ownerRepo"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "capsule_surface": {
          "$ref": "#/$defs/surfaceRef"
        },
        "authority_surface": {
          "$ref": "#/$defs/surfaceRef"
        },
        "next_actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/nextAction"
          }
        },
        "fallback": {
          "$ref": "#/$defs/nextAction"
        },
        "risk": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "next_hops": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/nextHop"
          }
        }
      }
    },
    "rootEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/entryBase"
        }
      ],
      "unevaluatedProperties": false
    },
    "entrypoint": {
      "allOf": [
        {
          "$ref": "#/$defs/entryBase"
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "$ref": "#/$defs/activeEntryKind"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "sourceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repo",
        "role",
        "ref"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repo": {
          "$ref": "#/$defs/repoName"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
