{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/two-stage-router-manifest.schema.json",
  "title": "aoa-routing two-stage router manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "profile",
    "policy_ref",
    "validation_refs",
    "integration_mode",
    "stage_1_token_budget",
    "stage_2_shortlist_limit",
    "skill_root_starter",
    "source_inputs",
    "skill_count",
    "band_count",
    "example_count",
    "eval_case_count",
    "base_entrypoint_count",
    "router_skill_entry_count",
    "pairing_entry_count",
    "task_hint_kinds"
  ],
  "properties": {
    "schema_version": { "const": "aoa_routing_two_stage_router_manifest_v2" },
    "schema_ref": { "const": "schemas/two-stage-router-manifest.schema.json" },
    "owner_repo": { "const": "aoa-routing" },
    "surface_kind": { "const": "two_stage_router_manifest" },
    "profile": { "const": "aoa-routing-wave-9-two-stage-skill-router" },
    "policy_ref": { "type": "string", "minLength": 1 },
    "validation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "integration_mode": { "const": "adjacent-seam" },
    "stage_1_token_budget": { "type": "integer", "minimum": 1 },
    "stage_2_shortlist_limit": { "type": "integer", "minimum": 1 },
    "skill_root_starter": { "type": "string", "minLength": 1 },
    "source_inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "skill_count": { "type": "integer", "minimum": 0 },
    "band_count": { "type": "integer", "minimum": 0 },
    "example_count": { "type": "integer", "minimum": 0 },
    "eval_case_count": { "type": "integer", "minimum": 0 },
    "base_entrypoint_count": { "type": "integer", "minimum": 0 },
    "router_skill_entry_count": { "type": "integer", "minimum": 0 },
    "pairing_entry_count": { "type": "integer", "minimum": 0 },
    "task_hint_kinds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
