{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/titan_console_route.schema.json",
  "title": "Titan Console Route",
  "type": "object",
  "required": [
    "version",
    "routes"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "intent",
          "titan",
          "gate"
        ],
        "properties": {
          "intent": {
            "enum": [
              "structure",
              "risk",
              "memory",
              "mutation",
              "judgment"
            ]
          },
          "titan": {
            "enum": [
              "Atlas",
              "Sentinel",
              "Mneme",
              "Forge",
              "Delta"
            ]
          },
          "gate": {
            "enum": [
              null,
              "mutation",
              "judgment"
            ]
          }
        },
        "additionalProperties": false,
        "oneOf": [
          {
            "properties": {
              "intent": {
                "const": "structure"
              },
              "titan": {
                "const": "Atlas"
              },
              "gate": {
                "const": null
              }
            }
          },
          {
            "properties": {
              "intent": {
                "const": "risk"
              },
              "titan": {
                "const": "Sentinel"
              },
              "gate": {
                "const": null
              }
            }
          },
          {
            "properties": {
              "intent": {
                "const": "memory"
              },
              "titan": {
                "const": "Mneme"
              },
              "gate": {
                "const": null
              }
            }
          },
          {
            "properties": {
              "intent": {
                "const": "mutation"
              },
              "titan": {
                "const": "Forge"
              },
              "gate": {
                "const": "mutation"
              }
            }
          },
          {
            "properties": {
              "intent": {
                "const": "judgment"
              },
              "titan": {
                "const": "Delta"
              },
              "gate": {
                "const": "judgment"
              }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
