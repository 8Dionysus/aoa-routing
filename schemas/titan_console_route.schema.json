{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/titan_console_route.schema.json",
  "title": "Titan Console Route",
  "type": "object",
  "required": [
    "version",
    "routes"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "intent",
          "titan",
          "gate"
        ],
        "properties": {
          "intent": {
            "enum": [
              "structure",
              "risk",
              "memory",
              "mutation",
              "judgment"
            ]
          },
          "titan": {
            "enum": [
              "Atlas",
              "Sentinel",
              "Mneme",
              "Forge",
              "Delta"
            ]
          },
          "gate": {
            "enum": [
              null,
              "mutation",
              "judgment"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
