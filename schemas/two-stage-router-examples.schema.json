{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/two-stage-router-examples.schema.json",
  "title": "aoa-routing two-stage router examples",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "profile",
    "policy_ref",
    "validation_refs",
    "examples"
  ],
  "properties": {
    "schema_version": { "const": "aoa_routing_two_stage_router_examples_v2" },
    "schema_ref": { "const": "schemas/two-stage-router-examples.schema.json" },
    "owner_repo": { "const": "aoa-routing" },
    "surface_kind": { "const": "two_stage_router_examples" },
    "profile": { "const": "aoa-routing-wave-9-two-stage-skill-router" },
    "policy_ref": { "type": "string", "minLength": 1 },
    "validation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "prompt",
          "preselect_result",
          "decision_packet"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "preselect_result": { "type": "object" },
          "decision_packet": { "type": "object" }
        }
      }
    }
  }
}
