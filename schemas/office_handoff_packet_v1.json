{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/aoa-routing/schemas/office_handoff_packet_v1.json",
  "title": "Office Handoff Packet V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "created_at",
    "evidence_refs",
    "id",
    "kind",
    "notes",
    "owner_repo",
    "receipt_required",
    "source_office",
    "state",
    "status",
    "target_office",
    "version"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "office_handoff_packet_v1"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1,
      "const": "aoa-routing"
    },
    "receipt_required": {
      "type": "boolean",
      "const": true
    },
    "source_office": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent"
      ],
      "properties": {
        "intent": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "active",
        "allowed",
        "applied",
        "blocked",
        "completed",
        "draft",
        "failed",
        "held",
        "passed",
        "proposed",
        "rejected",
        "rolled_back",
        "sealed"
      ]
    },
    "target_office": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "const": "1.1.0"
    }
  }
}
