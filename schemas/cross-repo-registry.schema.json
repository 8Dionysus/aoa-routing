{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/cross-repo-registry.schema.json",
  "title": "aoa-routing cross-repo registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "reserved_kinds",
    "entries"
  ],
  "properties": {
    "registry_version": {
      "const": 1
    },
    "reserved_kinds": {
      "type": "array",
      "items": {
        "const": "memo"
      },
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true
    },
    "entries": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "https://aoa-routing/schemas/router-entry.schema.json"
          },
          {
            "required": [
              "source_type",
              "attributes"
            ],
            "properties": {
              "source_type": {
                "const": "generated-catalog"
              },
              "attributes": {
                "type": "object"
              }
            }
          }
        ]
      }
    }
  }
}
