{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/two-stage-router-prompt-blocks.schema.json",
  "title": "aoa-routing two-stage router prompt blocks",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "profile",
    "policy_ref",
    "validation_refs",
    "stage_1_token_budget",
    "stage_2_shortlist_limit",
    "tiny_preselector_system",
    "main_model_decision_system",
    "handoff_contract"
  ],
  "properties": {
    "schema_version": { "const": "aoa_routing_two_stage_router_prompt_blocks_v2" },
    "schema_ref": { "const": "schemas/two-stage-router-prompt-blocks.schema.json" },
    "owner_repo": { "const": "aoa-routing" },
    "surface_kind": { "const": "two_stage_router_prompt_blocks" },
    "profile": { "const": "aoa-routing-wave-9-two-stage-skill-router" },
    "policy_ref": { "type": "string", "minLength": 1 },
    "validation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "stage_1_token_budget": { "type": "integer", "minimum": 1 },
    "stage_2_shortlist_limit": { "type": "integer", "minimum": 1 },
    "tiny_preselector_system": { "type": "string", "minLength": 1 },
    "main_model_decision_system": { "type": "string", "minLength": 1 },
    "handoff_contract": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
