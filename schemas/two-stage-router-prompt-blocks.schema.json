{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/two-stage-router-prompt-blocks.schema.json",
  "title": "aoa-routing two-stage router prompt blocks",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "tiny_preselector_system",
    "main_model_decision_system",
    "handoff_contract"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "const": "aoa-routing-wave-9-two-stage-skill-router" },
    "tiny_preselector_system": { "type": "string", "minLength": 1 },
    "main_model_decision_system": { "type": "string", "minLength": 1 },
    "handoff_contract": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
