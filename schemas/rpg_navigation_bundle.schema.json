{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/rpg_navigation_bundle_v1.schema.json",
  "title": "rpg_navigation_bundle_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority",
    "wave_scope",
    "inputs",
    "entries",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "rpg_navigation_bundle_v1"
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "wave_scope": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "surface_kind",
          "ref"
        ],
        "properties": {
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "surface_kind": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "entry_id",
          "quest_ref",
          "title",
          "owner_repo",
          "state",
          "band",
          "difficulty",
          "risk",
          "entry_actions",
          "inspect_ref",
          "party_hint",
          "loadout_hint",
          "unlock_hint",
          "reanchor_hint",
          "public_safe"
        ],
        "properties": {
          "schema_version": {
            "const": "rpg_navigation_card_v1"
          },
          "entry_id": {
            "type": "string",
            "minLength": 1
          },
          "quest_ref": {
            "type": "string",
            "minLength": 1
          },
          "playbook_ref": {
            "type": "string"
          },
          "party_template_ref": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "owner_repo": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "minLength": 1
          },
          "band": {
            "enum": [
              "frontier",
              "near",
              "latent",
              "parked"
            ]
          },
          "difficulty": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "source_dispatch_ref": {
            "type": "string"
          },
          "entry_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "inspect",
                "expand",
                "handoff"
              ]
            },
            "uniqueItems": true
          },
          "inspect_ref": {
            "type": "string",
            "minLength": 1
          },
          "expand_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "handoff_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "party_hint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template_id",
              "cohort_pattern",
              "required_roles",
              "slot_count",
              "recommended_tier_path"
            ],
            "properties": {
              "template_id": {
                "type": "string",
                "minLength": 1
              },
              "cohort_pattern": {
                "type": "string",
                "minLength": 1
              },
              "required_roles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "slot_count": {
                "type": "integer",
                "minimum": 1
              },
              "recommended_tier_path": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "loadout_hint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "required_ability_ids",
              "preferred_feat_ids",
              "notes"
            ],
            "properties": {
              "required_ability_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "preferred_feat_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "unlock_hint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "proof_ref",
              "verdict",
              "conditions",
              "caution"
            ],
            "properties": {
              "proof_ref": {
                "type": "string",
                "minLength": 1
              },
              "verdict": {
                "enum": [
                  "grant",
                  "gated_grant",
                  "hold",
                  "revoke"
                ]
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "caution": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "reanchor_hint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "return_mode",
              "source_ref"
            ],
            "properties": {
              "return_mode": {
                "type": "string",
                "minLength": 1
              },
              "source_ref": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "public_safe": {
            "type": "boolean"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
