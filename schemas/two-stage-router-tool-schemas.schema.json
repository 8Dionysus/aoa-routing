{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/two-stage-router-tool-schemas.schema.json",
  "title": "aoa-routing two-stage router tool schemas",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "profile",
    "policy_ref",
    "validation_refs",
    "low_context_boundary",
    "stage_2_shortlist_limit",
    "tools"
  ],
  "properties": {
    "schema_version": { "const": "aoa_routing_two_stage_router_tool_schemas_v2" },
    "schema_ref": { "const": "schemas/two-stage-router-tool-schemas.schema.json" },
    "owner_repo": { "const": "aoa-routing" },
    "surface_kind": { "const": "two_stage_router_tool_schemas" },
    "profile": { "const": "aoa-routing-wave-9-two-stage-skill-router" },
    "policy_ref": { "type": "string", "minLength": 1 },
    "validation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "low_context_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wording_scope",
        "source_payload_copying",
        "stage_1_source_refs",
        "stage_2_source_refs",
        "forbidden_source_payload_fields"
      ],
      "properties": {
        "wording_scope": { "const": "routing-owned" },
        "source_payload_copying": { "const": "forbidden" },
        "stage_1_source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "stage_2_source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "forbidden_source_payload_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "stage_2_shortlist_limit": { "type": "integer", "minimum": 1 },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "input_schema"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "input_schema": { "type": "object" }
        }
      }
    }
  }
}
