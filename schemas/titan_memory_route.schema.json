    "record_id",
    "source_ref",
    "owner_route"
  ],
  "properties": {
    "query": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "owner_route": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_note": {
      "type": "string"
    }
  }
}
