{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/titan_memory_route.schema.json",
  "title": "Titan Memory Route",
  "type": "object",
  "required": [
    "query",
    "record_id",
    "owner_route"
  ],
  "properties": {
    "query": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "owner_route": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "authority_note": {
      "type": "string"
    }
  },
  "anyOf": [
    {
      "required": [
        "source_ref"
      ]
    },
    {
      "required": [
        "session_id"
      ]
    }
  ],
  "additionalProperties": false
}
