{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/quest-dispatch-hints.schema.json",
  "title": "aoa-routing quest dispatch hints",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "wave_scope",
    "actions_enabled",
    "source_inputs",
    "hints"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "wave_scope": {
      "const": "source-only"
    },
    "actions_enabled": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "inspect",
          "expand",
          "handoff"
        ]
      }
    },
    "source_inputs": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/sourceInput"
      }
    },
    "hints": {
      "type": "array",
      "items": {
        "$ref": "https://8dionysus.github.io/schemas/quest_dispatch_hint_v2.schema.json"
      }
    }
  },
  "$defs": {
    "sourceRepo": {
      "type": "string",
      "enum": [
        "aoa-techniques",
        "aoa-skills",
        "aoa-evals"
      ]
    },
    "sourceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "surface_kind",
        "ref"
      ],
      "properties": {
        "repo": {
          "$ref": "#/$defs/sourceRepo"
        },
        "surface_kind": {
          "type": "string",
          "enum": [
            "quest_catalog",
            "quest_dispatch"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
