{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/harvest_quest_fanout_v1.json",
  "title": "harvest_quest_fanout_v1",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "status",
    "summary",
    "evidence_refs",
    "payload",
    "owner_repo"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "harvest_quest_fanout"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "captured",
        "candidate",
        "review",
        "approved",
        "blocked",
        "rejected",
        "promoted",
        "active",
        "retired",
        "scheduled",
        "passed",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "payload": {
      "type": "object",
      "required": [
        "candidate_id",
        "quests_created",
        "repos"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "quests_created": {
          "type": "integer",
          "minimum": 0
        },
        "repos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "additionalProperties": false
}
