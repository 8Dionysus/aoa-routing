{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-routing/schemas/aoa-router.schema.json",
  "title": "aoa-routing thin router projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "router_version",
    "entries"
  ],
  "properties": {
    "router_version": {
      "const": 1
    },
    "entries": {
      "type": "array",
        "items": {
          "oneOf": [
            {
              "$ref": "#/$defs/techniqueEntry"
            },
            {
              "$ref": "#/$defs/skillEntry"
            },
            {
              "$ref": "#/$defs/evalEntry"
            },
            {
              "$ref": "#/$defs/memoEntry"
            }
          ]
        }
      }
  },
  "$defs": {
    "thinProjectionEntry": {
      "allOf": [
        {
          "$ref": "https://aoa-routing/schemas/router-entry.schema.json"
        },
        {
          "not": {
            "anyOf": [
              {
                "required": [
                  "source_type"
                ]
              },
              {
                "required": [
                  "attributes"
                ]
              }
            ]
          }
        }
      ]
    },
    "techniqueEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/thinProjectionEntry"
        },
        {
          "properties": {
            "kind": {
              "const": "technique"
            },
            "repo": {
              "const": "aoa-techniques"
            }
          }
        }
      ]
    },
    "skillEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/thinProjectionEntry"
        },
        {
          "properties": {
            "kind": {
              "const": "skill"
            },
            "repo": {
              "const": "aoa-skills"
            }
          }
        }
      ]
    },
    "evalEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/thinProjectionEntry"
        },
        {
          "properties": {
            "kind": {
              "const": "eval"
            },
            "repo": {
              "const": "aoa-evals"
            }
          }
        }
      ]
    },
    "memoEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/thinProjectionEntry"
        },
        {
          "properties": {
            "kind": {
              "const": "memo"
            },
            "repo": {
              "const": "aoa-memo"
            }
          }
        }
      ]
    }
  }
}
