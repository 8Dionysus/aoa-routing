  "lifecycle": {
    "initial_state": "candidate",
    "promotion_path": [
      "candidate",
      "built-local",
      "manually-verified",
      "release-ready",
      "published",
      "superseded",
      "revoked"
    ],
    "latest_eligible_states": [
      "manually-verified",
      "release-ready",
      "published"
    ]
  },
  "consumer_contract": {
    "stable_interface": "python scripts/validate_abyss_machine_routing_bundle.py",
    "consumer_expectation": "Routing consumers select a thin_routing_readmodel_bundle from the registry latest read-model only after ABI verification, SBOM-lite subject inventory, SLSA/in-toto generation provenance, durable evidence promotion, materialized subject-store verification, source/trust-root matching, build_router --check, validate_router, and source-owned next-hop checks pass.",
    "registry_required": true,
    "subject_store_required": true,
    "admission_gate": "fail_closed_consumer_admission",
    "consumer_verdict": "allow_or_deny_required_before_use"
  },
  "consumer_command": [
    "abyss-machine artifacts build-sidecars --manifest docs/artifact-bundles/thin_router.bundle.json --bundle-dir BUNDLE_DIR",
    "abyss-machine artifacts sign BUNDLE_DIR",
    "abyss-machine artifacts verify BUNDLE_DIR",
    "abyss-machine artifacts release-check BUNDLE_DIR",
    "abyss-machine artifacts evidence-promote BUNDLE_DIR --registry-dir REGISTRY_DIR --lifecycle-state release-ready --consumer-ref aoa-routing:thin-router-readmodel --evidence-ref BUNDLE_DIR/artifact.verify.json --source-repo aoa-routing --source-ref docs/artifact-bundles/thin_router.bundle.json --producer aoa-routing-thin-router-readmodel-builder --trust-root-mode host_managed --json",
    "abyss-machine artifacts materialize-subjects BUNDLE_DIR --store-root SUBJECT_STORE_ROOT --registry-dir REGISTRY_DIR --manifest docs/artifact-bundles/thin_router.bundle.json --consumer-intent agent --source-repo aoa-routing --trust-root-mode host_managed --json",
    "abyss-machine artifacts trust-gate --registry-dir REGISTRY_DIR --artifact-class thin_routing_readmodel_bundle --consumer-intent agent --source-repo aoa-routing --trust-root-mode host_managed --subject-digest SUBJECT_DIGEST --json",
    "abyss-machine artifacts registry-latest --registry-dir REGISTRY_DIR --artifact-class thin_routing_readmodel_bundle --consumer-intent agent --source-repo aoa-routing --trust-root-mode host_managed --json"
  ]
}
